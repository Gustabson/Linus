generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH (NextAuth compatible) ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USERS ────────────────────────────────────────────────────────────────────

enum UserRole {
  VIEWER
  EDUCATOR
  MAINTAINER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(EDUCATOR)
  bio           String?
  website       String?
  location      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  ownedTrees          DocumentTree[]    @relation("TreeOwner")
  memberships         TreeMembership[]
  committedVersions   DocumentVersion[]
  proposals           ChangeProposal[]  @relation("ProposalAuthor")
  reviewedProposals   ChangeProposal[]  @relation("ProposalReviewer")
  ledgerEntries       LedgerEntry[]
  likes               TreeLike[]
  extensions          TreeExtension[]
  comments            DocumentComment[]
  addedAttachments    TreeAttachment[]  @relation("AttachmentAddedBy")
  followers               UserFollow[]         @relation("Following")
  following               UserFollow[]         @relation("Follower")
  notificationsReceived   Notification[]       @relation("NotificationRecipient")
  notificationsGiven      Notification[]       @relation("NotificationActor")
}

// ─── DOCUMENT TREES (kernels, modules, resources) ────────────────────────────

enum TreeVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum ContentType {
  KERNEL
  MODULE
  RESOURCE
}

model DocumentTree {
  id           String         @id @default(cuid())
  slug         String         @unique
  title        String
  description  String?
  language     String         @default("es")
  visibility   TreeVisibility @default(PUBLIC)
  contentType  ContentType    @default(KERNEL)
  forkDepth    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // ── Publication seal ─────────────────────────────────────────────────────
  // Set when the owner explicitly publishes. The hash covers ALL documents
  // inside this tree so one fingerprint certifies the whole entity.
  contentHash          String?
  publishedAt          DateTime?
  publishCommitMessage String?

  ownerId      String
  owner        User           @relation("TreeOwner", fields: [ownerId], references: [id])

  parentTreeId String?
  parentTree   DocumentTree?  @relation("ForkTree", fields: [parentTreeId], references: [id])
  forks        DocumentTree[] @relation("ForkTree")

  documents    Document[]
  memberships  TreeMembership[]
  proposalsFrom ChangeProposal[] @relation("SourceTree")
  proposalsTo   ChangeProposal[] @relation("TargetTree")
  likes        TreeLike[]
  extensions   TreeExtension[]

  // Modules/Resources attached to this kernel
  attachments  TreeAttachment[] @relation("KernelAttachments")
  // Kernels this module/resource is attached to
  attachedTo   TreeAttachment[] @relation("AttachedContent")

  @@index([ownerId])
  @@index([parentTreeId])
  @@index([contentType])
}

model TreeAttachment {
  id        String   @id @default(cuid())
  addedAt   DateTime @default(now())

  kernelId  String
  kernel    DocumentTree @relation("KernelAttachments", fields: [kernelId], references: [id], onDelete: Cascade)

  contentId String
  content   DocumentTree @relation("AttachedContent", fields: [contentId], references: [id], onDelete: Cascade)

  addedById String
  addedBy   User @relation("AttachmentAddedBy", fields: [addedById], references: [id])

  @@unique([kernelId, contentId])
  @@index([kernelId])
  @@index([contentId])
}

enum MemberRole {
  OWNER
  MAINTAINER
  CONTRIBUTOR
}

model TreeMembership {
  id        String     @id @default(cuid())
  role      MemberRole
  createdAt DateTime   @default(now())

  treeId    String
  tree      DocumentTree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([treeId, userId])
}

// ─── DOCUMENTS ────────────────────────────────────────────────────────────────

model Document {
  id        String   @id @default(cuid())
  slug      String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  treeId    String
  tree      DocumentTree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  currentVersionId String?
  versions         DocumentVersion[]
  comments         DocumentComment[]

  @@unique([treeId, slug])
  @@index([treeId])
}

enum VersionStatus {
  DRAFT
  PUBLISHED
}

model DocumentVersion {
  id            String        @id @default(cuid())
  commitMessage String        @default("")
  contentHash   String?                           // null for drafts; meaningful hash on publish
  status        VersionStatus @default(PUBLISHED) // PUBLISHED default preserves existing records
  createdAt     DateTime      @default(now())

  documentId      String
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  authorId        String
  author          User     @relation(fields: [authorId], references: [id])

  parentVersionId String?
  parentVersion   DocumentVersion?  @relation("VersionHistory", fields: [parentVersionId], references: [id])
  childVersions   DocumentVersion[] @relation("VersionHistory")

  sections        DocumentSection[]

  @@index([documentId])
  @@index([authorId])
  @@index([documentId, status])
}

// ─── SECTIONS ─────────────────────────────────────────────────────────────────

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model DocumentSection {
  id               String          @id @default(cuid())
  sectionType      String          // free-form user-defined section title
  sectionOrder     Int
  difficultyLevel  DifficultyLevel @default(BEGINNER)
  ageRangeMin      Int?
  ageRangeMax      Int?
  gradeLevel       String?
  durationMinutes  Int?
  isComplete       Boolean         @default(false)
  richTextContent  Json
  createdAt        DateTime        @default(now())

  versionId String
  version   DocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([versionId, sectionOrder])
}

// ─── COMMENTS ─────────────────────────────────────────────────────────────────

model DocumentComment {
  id          String   @id @default(cuid())
  content     String
  quotedText  String?
  sectionType String?
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([authorId])
}

// ─── CHANGE PROPOSALS (pull requests) ─────────────────────────────────────────

enum ProposalStatus {
  OPEN
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model ChangeProposal {
  id          String         @id @default(cuid())
  title       String
  description String?
  status      ProposalStatus @default(OPEN)
  createdAt   DateTime       @default(now())
  reviewedAt  DateTime?

  sourceTreeId String
  sourceTree   DocumentTree @relation("SourceTree", fields: [sourceTreeId], references: [id])

  targetTreeId String
  targetTree   DocumentTree @relation("TargetTree", fields: [targetTreeId], references: [id])

  authorId   String
  author     User   @relation("ProposalAuthor", fields: [authorId], references: [id])

  reviewerId String?
  reviewer   User?  @relation("ProposalReviewer", fields: [reviewerId], references: [id])

  @@index([sourceTreeId])
  @@index([targetTreeId])
  @@index([status])
}

// ─── LEDGER (append-only audit chain) ─────────────────────────────────────────

enum LedgerEventType {
  // Account
  ACCOUNT_CREATED
  // Tree
  TREE_CREATED
  TREE_FORKED
  TREE_VISIBILITY_CHANGED
  TREE_ARCHIVED
  // Document
  DOCUMENT_CREATED
  VERSION_COMMITTED
  // Proposals
  PROPOSAL_OPENED
  PROPOSAL_REVIEWED
  PROPOSAL_MERGED
  PROPOSAL_WITHDRAWN
  // Export
  DOCUMENT_EXPORTED
  // Social
  COMMENT_ADDED
  USERNAME_SET
  USER_FOLLOWED
  USER_UNFOLLOWED
  // Attachments
  CONTENT_ATTACHED
  CONTENT_DETACHED
}

model LedgerEntry {
  id                Int             @id @default(autoincrement())
  eventType         LedgerEventType
  subjectId         String
  subjectType       String
  eventPayload      Json
  eventTimestamp    DateTime        @default(now())
  previousEntryHash String?
  entryHash         String          @unique

  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([subjectId])
  @@index([eventType])
  @@index([eventTimestamp])
}

// ─── FOLLOWS ──────────────────────────────────────────────────────────────────

model UserFollow {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  followerId  String
  follower    User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)

  followingId String
  following   User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ─── LIKES ────────────────────────────────────────────────────────────────────

model TreeLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  treeId String
  tree   DocumentTree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([treeId, userId])
  @@index([treeId])
  @@index([userId])
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

enum NotificationType {
  NEW_FOLLOWER
  NEW_FORK
  NEW_LIKE
  NEW_COMMENT
  NEW_PROPOSAL
  PROPOSAL_REVIEWED
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  read        Boolean          @default(false)
  link        String           // pre-computed URL to navigate to
  createdAt   DateTime         @default(now())

  recipientId String
  recipient   User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  actorId     String
  actor       User   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([recipientId, read])
  @@index([recipientId, createdAt])
}

// ─── EXTENSIONS (links, apps, images attached to a tree) ─────────────────────

enum ExtensionType {
  LINK
  APP
  IMAGE
  VIDEO
  FILE
  TOOL
}

model TreeExtension {
  id          String        @id @default(cuid())
  type        ExtensionType
  title       String
  description String?
  url         String?
  imageUrl    String?
  isPinned    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  treeId String
  tree   DocumentTree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([treeId])
}
