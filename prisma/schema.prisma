generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH (NextAuth compatible) ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USERS ────────────────────────────────────────────────────────────────────

enum UserRole {
  VIEWER
  EDUCATOR
  MAINTAINER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(EDUCATOR)
  bio           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  ownedTrees     DocumentTree[]    @relation("TreeOwner")
  memberships    TreeMembership[]
  committedVersions DocumentVersion[]
  proposals      ChangeProposal[]  @relation("ProposalAuthor")
  reviewedProposals ChangeProposal[] @relation("ProposalReviewer")
  ledgerEntries  LedgerEntry[]
}

// ─── DOCUMENT TREES (repos) ───────────────────────────────────────────────────

enum TreeVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

model DocumentTree {
  id           String         @id @default(cuid())
  slug         String         @unique
  title        String
  description  String?
  language     String         @default("es")
  visibility   TreeVisibility @default(PUBLIC)
  isKernel     Boolean        @default(false)
  forkDepth    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  ownerId      String
  owner        User           @relation("TreeOwner", fields: [ownerId], references: [id])

  parentTreeId String?
  parentTree   DocumentTree?  @relation("ForkTree", fields: [parentTreeId], references: [id])
  forks        DocumentTree[] @relation("ForkTree")

  documents    Document[]
  memberships  TreeMembership[]
  proposalsFrom ChangeProposal[] @relation("SourceTree")
  proposalsTo   ChangeProposal[] @relation("TargetTree")

  @@index([ownerId])
  @@index([parentTreeId])
  @@index([isKernel])
}

enum MemberRole {
  OWNER
  MAINTAINER
  CONTRIBUTOR
}

model TreeMembership {
  id        String     @id @default(cuid())
  role      MemberRole
  createdAt DateTime   @default(now())

  treeId    String
  tree      DocumentTree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([treeId, userId])
}

// ─── DOCUMENTS ────────────────────────────────────────────────────────────────

model Document {
  id        String   @id @default(cuid())
  slug      String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  treeId    String
  tree      DocumentTree @relation(fields: [treeId], references: [id], onDelete: Cascade)

  currentVersionId String?
  versions         DocumentVersion[]

  @@unique([treeId, slug])
  @@index([treeId])
}

model DocumentVersion {
  id            String   @id @default(cuid())
  commitMessage String
  contentHash   String
  createdAt     DateTime @default(now())

  documentId      String
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  authorId        String
  author          User     @relation(fields: [authorId], references: [id])

  parentVersionId String?
  parentVersion   DocumentVersion?  @relation("VersionHistory", fields: [parentVersionId], references: [id])
  childVersions   DocumentVersion[] @relation("VersionHistory")

  sections        DocumentSection[]

  @@index([documentId])
  @@index([authorId])
}

// ─── SECTIONS ─────────────────────────────────────────────────────────────────

enum SectionType {
  PHILOSOPHY
  BEHAVIOR
  EXERCISES
  PROBLEMS
  ANTI_BULLYING
  ECONOMY
  SCIENTIFIC_METHOD
  ETHICS
  ASSESSMENT
  RESOURCES
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model DocumentSection {
  id               String          @id @default(cuid())
  sectionType      SectionType
  sectionOrder     Int
  difficultyLevel  DifficultyLevel @default(BEGINNER)
  ageRangeMin      Int?
  ageRangeMax      Int?
  gradeLevel       String?
  durationMinutes  Int?
  isComplete       Boolean         @default(false)
  richTextContent  Json
  createdAt        DateTime        @default(now())

  versionId String
  version   DocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, sectionType])
  @@index([versionId])
}

// ─── CHANGE PROPOSALS (pull requests) ─────────────────────────────────────────

enum ProposalStatus {
  OPEN
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model ChangeProposal {
  id          String         @id @default(cuid())
  title       String
  description String?
  status      ProposalStatus @default(OPEN)
  createdAt   DateTime       @default(now())
  reviewedAt  DateTime?

  sourceTreeId String
  sourceTree   DocumentTree @relation("SourceTree", fields: [sourceTreeId], references: [id])

  targetTreeId String
  targetTree   DocumentTree @relation("TargetTree", fields: [targetTreeId], references: [id])

  authorId   String
  author     User   @relation("ProposalAuthor", fields: [authorId], references: [id])

  reviewerId String?
  reviewer   User?  @relation("ProposalReviewer", fields: [reviewerId], references: [id])

  @@index([sourceTreeId])
  @@index([targetTreeId])
  @@index([status])
}

// ─── LEDGER (append-only audit chain) ─────────────────────────────────────────

enum LedgerEventType {
  // Account
  ACCOUNT_CREATED
  // Tree
  TREE_CREATED
  TREE_FORKED
  TREE_VISIBILITY_CHANGED
  TREE_ARCHIVED
  // Document
  DOCUMENT_CREATED
  VERSION_COMMITTED
  // Proposals
  PROPOSAL_OPENED
  PROPOSAL_REVIEWED
  PROPOSAL_MERGED
  PROPOSAL_WITHDRAWN
  // Export
  DOCUMENT_EXPORTED
}

model LedgerEntry {
  id                Int             @id @default(autoincrement())
  eventType         LedgerEventType
  subjectId         String
  subjectType       String
  eventPayload      Json
  eventTimestamp    DateTime        @default(now())
  previousEntryHash String?
  entryHash         String          @unique

  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([subjectId])
  @@index([eventType])
  @@index([eventTimestamp])
}
